{
  "name": "emberpath",
  "version": "1.0.0",
  "scripts": {
    "backend": "cd backend && .venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
    "frontend": "cd frontend && bun run dev",
    "dev": "concurrently \"bun run backend\" \"bun run frontend\""
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}